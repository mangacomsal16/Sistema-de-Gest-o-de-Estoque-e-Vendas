# Credenciais do PostgreSQL usadas pelo docker-compose.yml (desenvolvimento local).
# Copie para .env e ajuste antes de subir o container: docker compose up -d
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=estoque_vendas
# Porta exposta no host — mude se 5432 já estiver em uso por outro PostgreSQL local.
POSTGRES_PORT=5432
