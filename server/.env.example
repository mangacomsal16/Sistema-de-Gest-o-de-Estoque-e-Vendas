# Conexão com o PostgreSQL (ajuste usuário, senha e nome do banco)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/estoque_vendas?schema=public"

# Porta da API
PORT=4000

# development | production — em produção, JWT_SECRET não pode ser o valor padrão abaixo
NODE_ENV=development

# Origem permitida no CORS (URL do frontend)
CLIENT_URL="http://localhost:5173"

# Segredo para assinar os tokens JWT.
# Em produção, gere um valor forte, por exemplo: openssl rand -base64 32
JWT_SECRET="troque-este-segredo-em-producao"
JWT_EXPIRES_IN="7d"
